{
  "name": "json-chat-viewer",
  "displayName": "JSON Chat Viewer",
  "description": "Read LLM chat logs as a clean transcript: Claude Code sessions, ChatGPT and Claude.ai exports, and raw OpenAI / Anthropic API logs.",
  "version": "0.2.2",
  "publisher": "emrah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hello-emrah/json-chat-viewer.git"
  },
  "homepage": "https://github.com/hello-emrah/json-chat-viewer#readme",
  "bugs": {
    "url": "https://github.com/hello-emrah/json-chat-viewer/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "chatgpt",
    "openai",
    "anthropic",
    "llm",
    "transcript",
    "conversations.json",
    "jsonl",
    "chat log viewer"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "customEditors": [
      {
        "viewType": "jsonChatViewer.transcript",
        "displayName": "Chat Transcript",
        "selector": [
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "jsonChatViewer.open",
        "title": "Open as Readable Transcript",
        "category": "Chat Viewer",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "jsonChatViewer.openText",
        "title": "Reopen as Raw JSON",
        "category": "Chat Viewer",
        "icon": "$(json)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jsonChatViewer.open",
          "when": "resourceExtname =~ /\\.jsonl?$/ && activeCustomEditorId != jsonChatViewer.transcript",
          "group": "navigation@1"
        },
        {
          "command": "jsonChatViewer.openText",
          "when": "activeCustomEditorId == jsonChatViewer.transcript",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "jsonChatViewer.open",
          "when": "resourceExtname =~ /\\.jsonl?$/",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonChatViewer.open",
          "when": "resourceExtname =~ /\\.jsonl?$/"
        },
        {
          "command": "jsonChatViewer.openText",
          "when": "resourceExtname =~ /\\.jsonl?$/"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
